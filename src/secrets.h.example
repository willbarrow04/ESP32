#pragma once

// ── WiFi ─────────────────────────────────────────────────────────────────────
#define WIFI_SSID     "YOUR_SSID"
#define WIFI_PASSWORD "YOUR_PASSWORD"

// ── Backend ──────────────────────────────────────────────────────────────────
#define BACKEND_BASE_URL    "https://YOUR_APP.azurewebsites.net"
#define BACKEND_API_KEY     "YOUR_POST_PROCESS_API_KEY"

// ── TLS trust bundle ─────────────────────────────────────────────────────────
// DigiCert Global Root G2 + G3 concatenated.
// Azure *.azurewebsites.net certs may chain to either root; both are needed.
//
// Source: https://www.digicert.com/kb/digicert-root-certificates.htm
//   - DigiCert Global Root G2  (SHA-256 thumbprint shown on that page)
//   - DigiCert Global Root G3  (SHA-384 thumbprint shown on that page)
//
// Paste each PEM below as one base64 line per quoted string ending in \n.
// Example line format:  "MIIDjjCCAnagAwIBAgIQAzrx...\n"  \
//
#define DIGICERT_CA_BUNDLE                                       \
  "-----BEGIN CERTIFICATE-----\n"                               \
  "PASTE_DIGICERT_GLOBAL_ROOT_G2_BASE64_LINES_HERE\n"           \
  "-----END CERTIFICATE-----\n"                                 \
  "-----BEGIN CERTIFICATE-----\n"                               \
  "PASTE_DIGICERT_GLOBAL_ROOT_G3_BASE64_LINES_HERE\n"           \
  "-----END CERTIFICATE-----\n"

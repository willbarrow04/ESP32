// ── Backend ──────────────────────────────────────────────────────────────────
#define BACKEND_BASE_URL    "https://bp-core-demo-orchestrator.azurewebsites.us"
#define BACKEND_API_KEY     "YOUR_POST_PROCESS_API_KEY"

// ── TLS trust bundle ─────────────────────────────────────────────────────────
// Azure Government (*.azurewebsites.us) — verify the actual root chain with:
//   openssl s_client -connect bp-core-demo-orchestrator.azurewebsites.us:443 -showcerts
// then paste each root PEM below.  Commercial Azure uses DigiCert G2/G3;
// Government may use DigiCert Global Root CA (original) or Microsoft RSA 2017.
//
// Paste each PEM below as one base64 line per quoted string ending in \n.
// Example line format:  "MIIDjjCCAnagAwIBAgIQAzrx...\n"  \
//
#define DIGICERT_CA_BUNDLE                                       \
  "-----BEGIN CERTIFICATE-----\n"                               \
  "PASTE_ROOT_CA_BASE64_LINES_HERE\n"                           \
  "-----END CERTIFICATE-----\n"
